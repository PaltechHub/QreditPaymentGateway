# ---------------------------------------------------------------------------
# Qredit Laravel SDK — environment variables
# ---------------------------------------------------------------------------
# Copy the relevant lines into your host Laravel app's `.env`. In a multi-tenant
# setup these are treated as DEFAULTS only — per-tenant credentials should be
# passed to Qredit::make() at runtime.

# --- Credentials -----------------------------------------------------------
QREDIT_API_KEY=
QREDIT_SECRET_KEY=

# --- Environment -----------------------------------------------------------
# true → sandbox URL, false → production URL.
QREDIT_SANDBOX=true
QREDIT_SANDBOX_URL=https://apitest.qredit.tech/gw-checkout/api/v1
QREDIT_PRODUCTION_URL=https://api.qredit.tech/gw-checkout/api/v1

# --- Signing ---------------------------------------------------------------
# Authorization header prefix required by the gateway.
QREDIT_AUTH_SCHEME=HmacSHA512_O
# Confirmed against live UAT: always 'upper' (lowercase rejects as Bad Signature).
QREDIT_SIGNATURE_CASE=upper

# --- Client headers --------------------------------------------------------
# Client-Type is fixed to 'TP' in the SDK — not overridable; other values
# lock you out of /auth/token. Client-Version is derived from the SDK's
# composer version at runtime (ccc + X.Y.Z) — only set this if Qredit has
# negotiated a specific version string for your integration.
# QREDIT_CLIENT_VERSION=ccc1.0
QREDIT_LANGUAGE=EN

# --- Token caching ---------------------------------------------------------
QREDIT_CACHE_TOKEN=true
QREDIT_TOKEN_CACHE_ENABLED=true
QREDIT_TOKEN_STRATEGY=cache
QREDIT_TOKEN_TTL_BUFFER=300

# --- Webhook --------------------------------------------------------------
QREDIT_WEBHOOK_ENABLED=false
QREDIT_WEBHOOK_PATH=/qredit/webhook
QREDIT_VERIFY_WEBHOOK_SIGNATURE=true

# --- Debug / logging ------------------------------------------------------
QREDIT_DEBUG=false
QREDIT_LOG_CHANNEL=stack
QREDIT_LOG_LEVEL=debug

# --- Retries + timeouts ---------------------------------------------------
QREDIT_CONNECT_TIMEOUT=30
QREDIT_REQUEST_TIMEOUT=60
QREDIT_RETRY_ENABLED=true
QREDIT_RETRY_MAX_ATTEMPTS=3
QREDIT_RETRY_DELAY=1000

# --- Defaults --------------------------------------------------------------
QREDIT_DEFAULT_CURRENCY=ILS
QREDIT_LOCK_ORDER_WHEN_PAID=false
QREDIT_PAYMENT_EXPIRATION_MINUTES=1440
