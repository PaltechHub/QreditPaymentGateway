{
    "name": "qredit/laravel-qredit",
    "description": "Laravel integration for Qredit payment gateway using Saloon PHP",
    "keywords": [
        "laravel",
        "payment",
        "qredit",
        "gateway",
        "saloon",
        "payment-gateway"
    ],
    "homepage": "https://github.com/qredit/laravel-qredit",
    "license": "MIT",
    "authors": [
        {
            "name": "PalTech Hub",
            "email": "shakerawad@paltechhub.com",
            "homepage": "https://www.paltechhub.com/"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "saloonphp/saloon": "^3.0",
        "saloonphp/laravel-plugin": "^3.0",
        "nesbot/carbon": "^2.0|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "pestphp/pest-plugin-arch": "^2.0|^3.0",
        "pestphp/pest-plugin-faker": "^2.0|^3.0",
        "pestphp/pest-plugin-watch": "^2.0|^3.0",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.10|^2.0",
        "larastan/larastan": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Qredit\\LaravelQredit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Qredit\\LaravelQredit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --colors=always",
        "test-coverage": "vendor/bin/pest --coverage --min=80",
        "test-watch": "vendor/bin/pest --watch",
        "test-parallel": "vendor/bin/pest --parallel",
        "test-type": "vendor/bin/pest --type-coverage",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "check": [
            "@format",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Qredit\\LaravelQredit\\QreditServiceProvider"
            ],
            "aliases": {
                "Qredit": "Qredit\\LaravelQredit\\Facades\\Qredit"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}